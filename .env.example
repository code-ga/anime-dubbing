# Replicate API Token (Required)
# Get your API token from https://replicate.com/ (or use HackClub proxy with HACK_CLUB_AI_API_KEY)
# This token is used for transcription and TTS services via Replicate
REPLICATE_API_TOKEN=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Replicate API Base URL (Optional)
# Override if using a custom Replicate proxy or instance
# Default: https://ai.hackclub.com/proxy/v1/replicate
REPLICATE_BASE_URL=https://ai.hackclub.com/proxy/v1/replicate

# HackClub AI / OpenRouter API Key (Required)
# Get your API key from https://ai.hackclub.com/
# Used for translation services via OpenRouter-compatible API
HACK_CLUB_AI_API_KEY=sk-hc-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HackClub AI Base URL (Optional)
# Override if using a custom OpenRouter-compatible endpoint
# Default: https://ai.hackclub.com/proxy/v1
HACK_CLUB_AI_BASE_URL=https://ai.hackclub.com/proxy/v1

# HuggingFace Token (Optional - for audio diarization)
# Only needed if enabling speaker diarization in replicate.ts
# Currently commented out in the codebase
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
